    if (screen === 'result' || screen === 'promotion') {
      const target = previousScreen;
      setScreen(target);
      setSearchState(DEFAULT_SEARCH_STATE);
    } else if (screen === 'search-input') {
      setScreen('home');
      setSearchState(DEFAULT_SEARCH_STATE);
    }
