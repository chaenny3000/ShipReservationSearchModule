  const resultFilterRef = useDraggableScroll(screen);

  const displayLabel = (selected, all, defaultLabel) => {
    if (selected.length === 0 || selected.length === all.length) return defaultLabel;
    if (selected.length === 1) return selected[0];
    return `${selected[0]} 외 ${selected.length - 1}`;
  };

  const formattedDate = (d) => `${d.month}/${d.day}(${WEEK[new Date(d.year, d.month - 1, d.day).getDay()]})`;

  const { filteredShips, queryOnlyShips, emptyCase } = useMemo(() => {
    const queryOnly = SHIPS_DATA.filter(ship => {
      const q = searchState.query.toLowerCase().trim();
      if (!q) return true;
      return ship.name.toLowerCase().includes(q) || ship.region.toLowerCase().includes(q) || ship.port.toLowerCase().includes(q);
    });
    const filtered = queryOnly.filter(ship => {
      if (searchSource === 'filter' || searchSource === 'query') {
        const regMatch = searchState.selectedRegions.length === 0 || searchState.selectedRegions.includes(ship.region);
        const fishMatch = searchState.selectedFishes.length === 0 || ship.fish.some(f => searchState.selectedFishes.includes(f));
        return regMatch && fishMatch;
      }
      return true;
    });
    const sorted = [...filtered].sort((a, b) => {
      if (sortOrder === 'price_low') return a.price - b.price;
      if (sortOrder === 'price_high') return b.price - a.price;
      if (sortOrder === 'seats') return b.seats - a.seats;
      return (a.ad === b.ad) ? b.reviews - a.reviews : a.ad ? -1 : 1;
    });
    return { 
      filteredShips: sorted, queryOnlyShips: queryOnly, 
      emptyCase: sorted.length === 0 ? (searchState.query && queryOnly.length === 0 ? 'no-query-match' : (searchState.query ? 'filter-mismatch' : 'no-filter-match')) : null 
    };
  }, [searchState, searchSource, sortOrder]);

