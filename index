                  <div className="flex flex-col gap-3 px-1 no-scrollbar">
                    {['recommend', 'price_low', 'price_high', 'seats'].map(key => (
                      <div key={key} onClick={() => { setSortOrder(key); closeBs(); }} className={`flex items-center justify-between h-14 px-5 rounded-2xl border transition-all cursor-pointer ${sortOrder === key ? 'border-blue-500 bg-blue-50 text-blue-600 font-black' : 'border-gray-100 bg-white text-slate-600'}`}>
                        <span className="text-[15px]">{sortLabel[key]}</span>{sortOrder === key && <CheckCircle2 className="w-5 h-5 text-blue-600" />}
                      </div>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </div>
        )}
      </div>
      <div className="toast fixed bottom-10 left-1/2 -translate-x-1/2 bg-black/80 text-white px-4 py-2 rounded-full text-xs font-bold hidden z-[9999] text-white" id="toast-msg" />
    </div>
  );
};

const showToast = (msg) => {
  const el = document.getElementById('toast-msg');
  if(!el) return;
  el.innerText = msg;
  el.style.display = 'block';
  setTimeout(() => { if(el) el.style.display = 'none'; }, 2000);
};

export default App;
